}

export interface MobileObservationRecord extends FullObservation {
    source_table: string
    source_row_id?: string
    entry_form?: MobileObservationEntryFormFields
    field_registry?: PredefinedField | null
}

/**
 * Fetch predefined field registry that collectors must pick from.
 * Priority:
 * 1. Hardcoded shapefile list (when enabled)
 * 2. Supabase `fields` table (if available)
 * 3. Fallback hardcoded list
 */
export async function fetchPredefinedFields(): Promise<PredefinedField[]> {
    if (USE_HARDCODED_FIELD_REGISTRY) {
        return HARDCODED_FIELDS.map((field, idx) => ({
            ...field,
            id: `hardcoded-${idx}`,
            geom: HARDCODED_FIELD_SHAPEFILE.features[idx]?.geometry,
        }))
    }

    try {
        const { data, error } = await supabase
            .from('fields')
            .select(`
                id,
                field_name,
                section_name,
                block_id,
                latitude,
                longitude,
                geom,
                created_at,
                created_by,
                date_recorded,
                is_synced,
                local_updated_at,
                updated_at
            `)
            .order('field_name', { ascending: true })

        if (error) {
            if (/relation|does not exist|undefined table/i.test(String(error.message || error))) {
                return HARDCODED_FIELDS.map((field, idx) => ({
                    ...field,
                    id: `hardcoded-${idx}`,
                    geom: HARDCODED_FIELD_SHAPEFILE.features[idx]?.geometry,
                }))
            }
            throw error
        }

        if (!data || data.length === 0) {
            return HARDCODED_FIELDS.map((field, idx) => ({
                ...field,
                id: `hardcoded-${idx}`,
                geom: HARDCODED_FIELD_SHAPEFILE.features[idx]?.geometry,
            }))
        }

        return data.map((row: any) => ({
            id: row.id,
            field_name: row.field_name,
            section_name: row.section_name,
            block_id: row.block_id,
            latitude: Number(row.latitude) || 0,
            longitude: Number(row.longitude) || 0,
            created_at: row.created_at || undefined,
            created_by: row.created_by || undefined,
            date_recorded: row.date_recorded || undefined,
            is_synced: typeof row.is_synced === 'boolean' ? row.is_synced : row.is_synced == null ? undefined : Boolean(row.is_synced),
            local_updated_at: row.local_updated_at || undefined,
            updated_at: row.updated_at || undefined,
            geom: row.geom,
            observation_count: 0,
        }))
    } catch (error) {
        console.warn('Failed to fetch predefined fields from backend, using hardcoded shapefile list.', error)
        return HARDCODED_FIELDS.map((field, idx) => ({
            ...field,
            id: `hardcoded-${idx}`,
            geom: HARDCODED_FIELD_SHAPEFILE.features[idx]?.geometry,
        }))
    }
}

export function getPredefinedFieldByName(
    fields: PredefinedField[],
    fieldName?: string | null
): PredefinedField | null {
    if (!fieldName) return null
    return fields.find((f) => f.field_name === fieldName) ?? null
}

type ObservationSelectRow = Omit<FullObservation, 'crop_information' | 'crop_monitoring'> & {
    crop_information?: FullObservation['crop_information'] | FullObservation['crop_information'][]
    crop_monitoring?: FullObservation['crop_monitoring'] | FullObservation['crop_monitoring'][]
}

type ObservationEntryFormRow = ObservationEntryForm & {
    id: number | string
}

const isMissingRelationError = (error: unknown): boolean =>
    /relation|does not exist|undefined table|schema cache/i.test(String((error as { message?: string })?.message || error))

function getSingleRelation<T>(value: T | T[] | null | undefined): T | undefined {
    if (Array.isArray(value)) {
        return value[0] ?? undefined
    }

    return value ?? undefined
}

function normalizeLookupToken(value?: string | null): string {
    return (value ?? '').trim().toLowerCase()
}

function extractLookupFieldCode(value?: string | null): string {
    const normalized = normalizeLookupToken(value).replace(/[^a-z0-9]+/g, ' ')
    const matches = normalized.match(/[a-z]+\d+[a-z0-9]*/g)
    return matches?.[matches.length - 1] ?? ''
}

function hasActiveFilterValue(value?: string | null): value is string {
    const normalized = normalizeLookupToken(value)
    return normalized.length > 0 && normalized !== 'all'
}

function buildFieldLookupKey(fieldName?: string | null, sectionName?: string | null, blockId?: string | null): string {
    return [normalizeLookupToken(fieldName), normalizeLookupToken(sectionName), normalizeLookupToken(blockId)].join('|')
}

function buildFieldLookupMaps(fields: PredefinedField[]) {
    const byIdentity = new Map<string, PredefinedField>()
    const bySection = new Map<string, PredefinedField>()
    const byName = new Map<string, PredefinedField>()
    const byBlock = new Map<string, PredefinedField>()
    const byCode = new Map<string, PredefinedField[]>()

    fields.forEach((field) => {
        const identityKey = buildFieldLookupKey(field.field_name, field.section_name, field.block_id)
        const sectionKey = [normalizeLookupToken(field.field_name), normalizeLookupToken(field.section_name)].join('|')
        const nameKey = normalizeLookupToken(field.field_name)
        const blockKey = normalizeLookupToken(field.block_id)

        if (!byIdentity.has(identityKey)) {
            byIdentity.set(identityKey, field)
        }

        if (sectionKey !== '|' && !bySection.has(sectionKey)) {
            bySection.set(sectionKey, field)
        }

        if (nameKey && !byName.has(nameKey)) {
            byName.set(nameKey, field)
        }

        if (blockKey && !byBlock.has(blockKey)) {
            byBlock.set(blockKey, field)
        }

        ;[extractLookupFieldCode(field.field_name), extractLookupFieldCode(field.block_id)].forEach((codeKey) => {
            if (!codeKey) return
            const group = byCode.get(codeKey) ?? []
            if (!group.includes(field)) {
                group.push(field)
            }
            byCode.set(codeKey, group)
        })
    })

    return { byIdentity, bySection, byName, byBlock, byCode }
}

function resolveLinkedFieldRegistry(
    row: {
        field_name?: string | null
        selected_field?: string | null
        section_name?: string | null
        block_id?: string | null
    },
    lookups: ReturnType<typeof buildFieldLookupMaps>
): PredefinedField | null {
    const candidateNames = [
        row.selected_field,
        row.field_name,
    ].filter((value, index, values): value is string => Boolean(normalizeLookupToken(value)) && values.indexOf(value) === index)

    for (const name of candidateNames) {
        const identityMatch = lookups.byIdentity.get(buildFieldLookupKey(name, row.section_name, row.block_id))
        if (identityMatch) {
            return identityMatch
        }
    }

    for (const name of candidateNames) {
        const sectionMatch = lookups.bySection.get([normalizeLookupToken(name), normalizeLookupToken(row.section_name)].join('|'))
        if (sectionMatch) {
            return sectionMatch
        }
    }

    for (const name of candidateNames) {
        const nameMatch = lookups.byName.get(normalizeLookupToken(name))
        if (nameMatch) {
            return nameMatch
        }
    }

    const blockMatch = lookups.byBlock.get(normalizeLookupToken(row.block_id))
    if (blockMatch) {
        return blockMatch
    }

    const codeCandidates = [
        extractLookupFieldCode(row.field_name),
        extractLookupFieldCode(row.selected_field),
        extractLookupFieldCode(row.block_id),
    ].filter(Boolean)

    for (const code of codeCandidates) {
        const codeMatches = lookups.byCode.get(code) ?? []
        if (codeMatches.length === 1) {
            return codeMatches[0]
        }
    }

    return null
}

function hasMeaningfulCoordinate(value?: number | null): value is number {
    return typeof value === 'number' && Number.isFinite(value) && value !== 0
}

function preferRegistryCoordinate(
    currentValue?: number | null,
    registryValue?: number | null
): number | undefined {
    if (hasMeaningfulCoordinate(currentValue)) return currentValue
    if (hasMeaningfulCoordinate(registryValue)) return registryValue
    if (typeof currentValue === 'number' && Number.isFinite(currentValue)) return currentValue
    if (typeof registryValue === 'number' && Number.isFinite(registryValue)) return registryValue
    return undefined
}

function applyRegistryFieldToSubmission(
    submission: ObservationEntryFormSubmissionInput,
    linkedField: PredefinedField
): ObservationEntryFormSubmissionInput {
    return {
        ...submission,
        selected_field: linkedField.field_name || submission.selected_field || submission.field_name,
        field_name: linkedField.field_name || submission.field_name,
        section_name: linkedField.section_name || submission.section_name,
        block_id: linkedField.block_id || submission.block_id,
        latitude: preferRegistryCoordinate(submission.latitude, linkedField.latitude),
        longitude: preferRegistryCoordinate(submission.longitude, linkedField.longitude),
        spatial_data: submission.spatial_data,
        crop_class: submission.crop_class || linkedField.crop_type || '',
    }
}

async function resolveObservationEntrySubmission(
    submission: ObservationEntryFormSubmissionInput,
    predefinedFields?: PredefinedField[]
): Promise<{
    submission: ObservationEntryFormSubmissionInput
    linkedField: PredefinedField | null
}> {
    const registryFields = predefinedFields ?? await fetchPredefinedFields().catch(() => [] as PredefinedField[])
    if (registryFields.length === 0) {
        return { submission, linkedField: null }
    }

    const linkedField = resolveLinkedFieldRegistry(
        {
            field_name: submission.field_name,
            selected_field: submission.selected_field,
            section_name: submission.section_name,
            block_id: submission.block_id,
        },
        buildFieldLookupMaps(registryFields)
    )

    if (!linkedField) {
        return { submission, linkedField: null }
    }

    return {
        submission: applyRegistryFieldToSubmission(submission, linkedField),
        linkedField,
    }
}

async function attachFieldRegistry(records: MobileObservationRecord[]): Promise<MobileObservationRecord[]> {
    if (records.length === 0) {
        return records
    }

    let registryFields: PredefinedField[] = []

    try {
        registryFields = await fetchPredefinedFields()
    } catch (error) {
        console.warn('Failed to load field registry while linking mobile records.', error)
        return records
    }

    if (registryFields.length === 0) {
        return records
    }

    const lookups = buildFieldLookupMaps(registryFields)

    return records.map((record) => {
        const linkedField = resolveLinkedFieldRegistry(
            {
                field_name: record.field_name,
                selected_field: record.entry_form?.selected_field,
                section_name: record.section_name,
                block_id: record.block_id,
            },
            lookups
        )

        return {
            ...record,
            field_registry: linkedField,
            entry_form: record.entry_form
                ? {
                    ...record.entry_form,
                    selected_field: record.entry_form.selected_field || linkedField?.field_name || record.field_name || undefined,
                }
                : record.entry_form,
        }
    })
}

function hasRelationValue(...values: unknown[]): boolean {
    return values.some((value) => {
        if (typeof value === 'string') {
            return value.trim().length > 0
        }

        return value !== null && value !== undefined
    })
}

function mapSugarcaneMonitoringRow(row: SugarcaneMonitoringRecord): MobileObservationRecord {
    const cropInformation = hasRelationValue(
        row.crop_type,
        row.variety,
        row.ratoon_number,
        row.crop_stage,
        row.planting_date,
        row.expected_harvest_date
    )
        ? {
            id: `${row.id}-crop-information`,
            observation_id: row.id,
            crop_type: row.crop_type || 'Sugarcane',
            ratoon_number: row.ratoon_number ?? 0,
            variety: row.variety || '',
            planting_date: row.planting_date || '',
            expected_harvest_date: row.expected_harvest_date || '',
            crop_stage: row.crop_stage || '',
        }
        : undefined

    const cropMonitoring = hasRelationValue(row.crop_vigor, row.canopy_cover, row.stress, row.remarks)
        ? {
            id: `${row.id}-crop-monitoring`,
            observation_id: row.id,
            crop_vigor: row.crop_vigor || '',
            canopy_cover: row.canopy_cover ?? 0,
            stress: row.stress || '',
            remarks: row.remarks || '',
        }
        : undefined

    const soilCharacteristics = hasRelationValue(
        row.soil_type,
        row.soil_texture,
        row.soil_ph,
        row.organic_matter,
        row.drainage_class
    )
        ? {
            id: `${row.id}-soil`,
            observation_id: row.id,
            soil_type: row.soil_type || '',
            soil_texture: row.soil_texture || '',
            soil_ph: row.soil_ph ?? 0,
            organic_matter: row.organic_matter ?? 0,
            drainage_class: row.drainage_class || '',
        }
        : undefined

    const irrigationManagement = hasRelationValue(
        row.irrigation_type,
        row.irrigation_date,
        row.irrigation_volume,
        row.soil_moisture_percentage,
        row.water_source
    )
        ? {
            id: `${row.id}-irrigation`,
            observation_id: row.id,
            irrigation_type: row.irrigation_type || '',
            irrigation_date: row.irrigation_date || '',
            irrigation_volume: row.irrigation_volume ?? 0,
            soil_moisture_percentage: row.soil_moisture_percentage ?? 0,
            water_source: row.water_source || '',
        }
        : undefined

    const nutrientManagement = hasRelationValue(
        row.fertilizer_type,
        row.fertilizer_application_date,
        row.application_rate,
        row.npk_ratio
    )
        ? {
            id: `${row.id}-nutrients`,
            observation_id: row.id,
            fertilizer_type: row.fertilizer_type || '',
            application_date: row.fertilizer_application_date || '',
            application_rate: row.application_rate ?? 0,
            npk_ratio: row.npk_ratio || '',
        }
        : undefined

    const cropProtection = hasRelationValue(
        row.weed_type,
        row.weed_level,
        row.pest_type,
        row.pest_severity,
        row.disease_type,
        row.disease_severity,
        row.remarks
    )
        ? {
            id: `${row.id}-protection`,
            observation_id: row.id,
            weed_type: row.weed_type || '',
            weed_level: row.weed_level || '',
            pest_type: row.pest_type || '',
            pest_severity: row.pest_severity || '',
            disease_type: row.disease_type || '',
            disease_severity: row.disease_severity || '',
            remarks: row.remarks || '',
        }
        : undefined

    const controlMethods = hasRelationValue(row.weed_control, row.pest_control, row.disease_control)
        ? {
            id: `${row.id}-control-methods`,
            observation_id: row.id,
            weed_control: row.weed_control || '',
            pest_control: row.pest_control || '',
            disease_control: row.disease_control || '',
        }
        : undefined

    const harvest = hasRelationValue(row.harvest_date, row.yield, row.harvest_method)
        ? {
            id: `${row.id}-harvest`,
            observation_id: row.id,
            harvest_date: row.harvest_date || '',
            yield: row.yield ?? 0,
            harvest_method: row.harvest_method || '',
        }
        : undefined

    const residualManagement = hasRelationValue(row.residue_type, row.residue_management_method)
        ? {
            id: `${row.id}-residual`,
            observation_id: row.id,
            residue_type: row.residue_type || '',
            management_method: row.residue_management_method || '',
            remarks: row.remarks || '',
        }
        : undefined

    const images = row.image_url
        ? [{
            id: `${row.id}-image`,
            observation_id: row.id,
            image_url: row.image_url,
            storage_path: row.image_url,
            taken_at: row.updated_at || row.created_at || row.date_recorded,
            uploaded_by: row.collector_id || 'system',
        }]
        : undefined

    return {
        id: row.id,
        client_uuid: row.id,
        collector_id: row.collector_id || '',
        section_name: row.section_name || '',
        block_id: row.block_id || '',
        field_name: row.field_name || 'Unknown field',
        latitude: row.latitude ?? 0,
        longitude: row.longitude ?? 0,
        gps_accuracy: 0,
        date_recorded: row.date_recorded,
        created_at: row.created_at,
        crop_information: cropInformation,
        crop_monitoring: cropMonitoring,
        soil_characteristics: soilCharacteristics,
        irrigation_management: irrigationManagement,
        nutrient_management: nutrientManagement,
        crop_protection: cropProtection,
        control_methods: controlMethods,
        harvest,
        residual_management: residualManagement,
        images,
        source_table: 'sugarcane_monitoring',
        source_row_id: row.id,
    }
}

export async function fetchSugarcaneMonitoringRows(filters?: ObservationFilters): Promise<SugarcaneMonitoringRecord[]> {
    let query = supabase
        .from('sugarcane_monitoring')
        .select('*')
        .order('date_recorded', { ascending: false })

    if (hasActiveFilterValue(filters?.cropType)) {
        query = query.eq('crop_type', filters.cropType)
    }
    if (hasActiveFilterValue(filters?.variety)) {
        query = query.eq('variety', filters.variety)
    }
    if (hasActiveFilterValue(filters?.fieldName)) {
        query = query.eq('field_name', filters.fieldName)
    }
    if (hasActiveFilterValue(filters?.section)) {
        query = query.eq('section_name', filters.section)
    }
    if (hasActiveFilterValue(filters?.block)) {
        query = query.eq('block_id', filters.block)
    }
    if (filters?.startDate) {
        query = query.gte('date_recorded', filters.startDate)
    }
    if (filters?.endDate) {
        query = query.lte('date_recorded', filters.endDate)
    }
    if (hasActiveFilterValue(filters?.stressLevel)) {
        query = query.eq('stress', filters.stressLevel)
    }

    const { data, error } = await query

    if (error) {
        throw error
    }

    return (data || []) as SugarcaneMonitoringRecord[]
}

export async function fetchSugarcaneMonitoringObservations(filters?: ObservationFilters): Promise<MobileObservationRecord[]> {
    try {
        const rows = await fetchSugarcaneMonitoringRows(filters)

        if (rows.length === 0) {
            return []
        }

        return attachFieldRegistry(rows.map(mapSugarcaneMonitoringRow))
    } catch (error) {
        if (isMissingRelationError(error)) {
            return []
        }

        throw error
    }
}

function normalizeObservationRow(row: ObservationSelectRow): FullObservation {
    return {
        ...row,
        crop_information: getSingleRelation(row.crop_information),
        crop_monitoring: getSingleRelation(row.crop_monitoring),
    }
}

function mapPrimaryMobileObservation(row: ObservationSelectRow): MobileObservationRecord {
    return {
        ...normalizeObservationRow(row),
        source_table: 'observations',
        source_row_id: String(row.id),
    }
}

function mapLegacyMobileRow(row: Record<string, unknown>, sourceTable: string): MobileObservationRecord {
    const cropType = String(row.crop_type || row.crop_class || '')
    const variety = String(row.variety || '')
    const cropStage = String(row.crop_stage || '')
    const stress = String(row.stress || '')
    const remarks = String(row.remarks || '')
    const normalizedId = String(row.id || row._id || row.uuid || row.client_uuid || `${sourceTable}-${Date.now()}`)

    return {
        id: normalizedId,
        source_row_id: normalizedId,
        client_uuid: typeof row.client_uuid === 'string' ? row.client_uuid : typeof row.clientId === 'string' ? row.clientId : undefined,
        collector_id: String(row.collector_id || row.user_id || row.created_by || ''),
        section_name: String(row.section_name || row.section || row.zone || ''),
        block_id: String(row.block_id || row.block || row.block_number || ''),
        field_name: String(row.field_name || row.field || row.fieldId || row.selected_field || ''),
        latitude: Number(row.latitude || row.lat || (row.coords as { lat?: number } | undefined)?.lat || (row.location as { lat?: number } | undefined)?.lat || 0),
        longitude: Number(row.longitude || row.lon || row.lng || (row.coords as { lng?: number } | undefined)?.lng || (row.location as { lng?: number } | undefined)?.lng || 0),
        gps_accuracy: Number(row.gps_accuracy || row.accuracy || 0),
        date_recorded: String(row.date_recorded || row.recorded_at || row.created_at || row.timestamp || new Date().toISOString()),
        created_at: String(row.created_at || row.timestamp || new Date().toISOString()),
        crop_information: cropType || variety || cropStage
            ? {
                id: String(row.id || row._id || row.uuid || row.client_uuid || sourceTable),
                observation_id: String(row.id || row._id || row.uuid || row.client_uuid || sourceTable),
                crop_type: cropType,
                ratoon_number: 0,
                variety,
                planting_date: '',
                expected_harvest_date: '',
                crop_stage: cropStage,
            }
            : undefined,
        crop_monitoring: stress || remarks || row.canopy_cover
            ? {
                id: String(row.id || row._id || row.uuid || row.client_uuid || sourceTable),
                observation_id: String(row.id || row._id || row.uuid || row.client_uuid || sourceTable),
                crop_vigor: String(row.crop_vigor || ''),
                canopy_cover: Number(row.canopy_cover || 0),
                stress,
                remarks,
            }
            : undefined,
        source_table: sourceTable,
    }
}

function isMobileObservationRecord(record: FullObservation | MobileObservationRecord): record is MobileObservationRecord {
    return 'source_table' in record
}

function getObservationMergeKey(record: Pick<FullObservation, 'id' | 'client_uuid'> & Partial<Pick<MobileObservationRecord, 'source_table' | 'source_row_id'>>): string {
    const normalizedClientUuid = normalizeLookupToken(record.client_uuid)
    if (normalizedClientUuid) {
        return `client:${normalizedClientUuid}`
    }

    const fallbackId = String(record.source_row_id || record.id || '').trim()
    const sourceTable = record.source_table || 'observations'
    return `${sourceTable}:${fallbackId}`
}

function compareObservationDates(left: Pick<FullObservation, 'date_recorded' | 'created_at'>, right: Pick<FullObservation, 'date_recorded' | 'created_at'>): number {
    const leftTimestamp = Date.parse(left.date_recorded || left.created_at || '') || 0
    const rightTimestamp = Date.parse(right.date_recorded || right.created_at || '') || 0
    return rightTimestamp - leftTimestamp
}

function sortObservationsByDate<T extends Pick<FullObservation, 'date_recorded' | 'created_at'>>(records: T[]): T[] {
    return [...records].sort(compareObservationDates)
}

function mergeObservationLike<T extends FullObservation>(
    baseRecord: T,
    incomingRecord: Partial<MobileObservationRecord>
): T & Partial<MobileObservationRecord> {
    const mergedRecord = {
        ...baseRecord,
        client_uuid: baseRecord.client_uuid || incomingRecord.client_uuid,
        collector_id: baseRecord.collector_id || incomingRecord.collector_id || '',
        section_name: baseRecord.section_name || incomingRecord.section_name || '',
        block_id: baseRecord.block_id || incomingRecord.block_id || '',
        field_name: baseRecord.field_name || incomingRecord.field_name || incomingRecord.entry_form?.selected_field || '',
        latitude: Number(baseRecord.latitude || incomingRecord.latitude || 0),
        longitude: Number(baseRecord.longitude || incomingRecord.longitude || 0),
        gps_accuracy: Number(baseRecord.gps_accuracy || incomingRecord.gps_accuracy || 0),
        date_recorded: baseRecord.date_recorded || incomingRecord.date_recorded || incomingRecord.entry_form?.date_recorded || baseRecord.created_at || incomingRecord.created_at || new Date().toISOString(),
        created_at: baseRecord.created_at || incomingRecord.created_at || incomingRecord.date_recorded || new Date().toISOString(),
        crop_information: baseRecord.crop_information || incomingRecord.crop_information,
        crop_monitoring: baseRecord.crop_monitoring || incomingRecord.crop_monitoring,
        soil_characteristics: baseRecord.soil_characteristics || incomingRecord.soil_characteristics,
        irrigation_management: baseRecord.irrigation_management || incomingRecord.irrigation_management,
        nutrient_management: baseRecord.nutrient_management || incomingRecord.nutrient_management,
        crop_protection: baseRecord.crop_protection || incomingRecord.crop_protection,
        control_methods: baseRecord.control_methods || incomingRecord.control_methods,
        harvest: baseRecord.harvest || incomingRecord.harvest,
        residual_management: baseRecord.residual_management || incomingRecord.residual_management,
        images: baseRecord.images?.length ? baseRecord.images : incomingRecord.images,
    } as T & Partial<MobileObservationRecord>

    if (incomingRecord.entry_form && !mergedRecord.entry_form) {
        mergedRecord.entry_form = incomingRecord.entry_form
    }

    if (incomingRecord.field_registry && !mergedRecord.field_registry) {
        mergedRecord.field_registry = incomingRecord.field_registry
    }

    if (incomingRecord.source_table && !mergedRecord.source_table) {
        mergedRecord.source_table = incomingRecord.source_table
    }

    if (incomingRecord.source_row_id && !mergedRecord.source_row_id) {
        mergedRecord.source_row_id = incomingRecord.source_row_id
    }

    return mergedRecord
}

function mergeMobileObservationCollections(
    preferredRecords: MobileObservationRecord[],
    fallbackRecords: MobileObservationRecord[]
): MobileObservationRecord[] {
    const mergedRecords = new Map<string, MobileObservationRecord>()

    preferredRecords.forEach((record) => {
        mergedRecords.set(getObservationMergeKey(record), record)
    })

    fallbackRecords.forEach((record) => {
        const mergeKey = getObservationMergeKey(record)
        const existingRecord = mergedRecords.get(mergeKey)

        if (!existingRecord) {
            mergedRecords.set(mergeKey, record)
            return
        }

        mergedRecords.set(mergeKey, mergeObservationLike(existingRecord, record) as MobileObservationRecord)
    })

    return sortObservationsByDate(Array.from(mergedRecords.values()))
}

function mergeObservationCollections(
    preferredRecords: FullObservation[],
    fallbackRecords: FullObservation[]
): FullObservation[] {
    const mergedRecords = new Map<string, FullObservation>()

    preferredRecords.forEach((record) => {
        mergedRecords.set(getObservationMergeKey(record), record)
    })

    fallbackRecords.forEach((record) => {
        const mergeKey = getObservationMergeKey(record)
        const existingRecord = mergedRecords.get(mergeKey)

        if (!existingRecord) {
            mergedRecords.set(mergeKey, record)
            return
        }

        mergedRecords.set(
            mergeKey,
            mergeObservationLike(existingRecord, record as Partial<MobileObservationRecord>) as FullObservation
        )
    })

    return sortObservationsByDate(Array.from(mergedRecords.values()))
}

function matchesObservationFilters(record: FullObservation, filters?: ObservationFilters): boolean {
    if (!filters) {
        return true
    }

    if (hasActiveFilterValue(filters.cropType)) {
        const cropType = normalizeLookupToken(record.crop_information?.crop_type)
        if (cropType !== normalizeLookupToken(filters.cropType)) {
            return false
        }
    }

    if (hasActiveFilterValue(filters.variety)) {
        const variety = normalizeLookupToken(record.crop_information?.variety)
        if (variety !== normalizeLookupToken(filters.variety)) {
            return false
        }
    }

    if (hasActiveFilterValue(filters.fieldName)) {
        const fieldName = normalizeLookupToken(record.field_name)
        if (fieldName !== normalizeLookupToken(filters.fieldName)) {
            return false
        }
    }

    if (hasActiveFilterValue(filters.section)) {
        const sectionName = normalizeLookupToken(record.section_name)
        if (sectionName !== normalizeLookupToken(filters.section)) {
            return false
        }
    }

    if (hasActiveFilterValue(filters.block)) {
        const blockId = normalizeLookupToken(record.block_id)
        if (blockId !== normalizeLookupToken(filters.block)) {
            return false
        }
    }

    if (hasActiveFilterValue(filters.stressLevel)) {
        const stressLevel = normalizeLookupToken(record.crop_monitoring?.stress)
        if (stressLevel !== normalizeLookupToken(filters.stressLevel)) {
            return false
        }
    }

    const recordedAt = Date.parse(record.date_recorded || record.created_at || '')

    if (filters.startDate) {
        const startTimestamp = Date.parse(filters.startDate)
        if (Number.isFinite(startTimestamp) && Number.isFinite(recordedAt) && recordedAt < startTimestamp) {
            return false
        }
    }

    if (filters.endDate) {
        const endTimestamp = Date.parse(filters.endDate)
        if (Number.isFinite(endTimestamp) && Number.isFinite(recordedAt) && recordedAt > endTimestamp) {
            return false
        }
    }

    return true
}

function filterObservations<T extends FullObservation>(records: T[], filters?: ObservationFilters): T[] {
    return records.filter((record) => matchesObservationFilters(record, filters))
}

function toNullableString(value: unknown): string | null {
    if (typeof value !== 'string') return value == null ? null : String(value)
    const trimmed = value.trim()
    return trimmed.length > 0 ? trimmed : null
}

function toNullableNumber(value: unknown): number | null {
    if (value === null || value === undefined || value === '') return null

    if (typeof value === 'number') {
        return Number.isFinite(value) ? value : null
    }

    const compact = String(value).trim().replace(/\s+/g, '').replace(/[^0-9,.-]/g, '')
    if (!compact) return null

    let candidate = compact
    const hasComma = candidate.includes(',')
    const hasDot = candidate.includes('.')

    if (hasComma && hasDot) {
        candidate = candidate.lastIndexOf(',') > candidate.lastIndexOf('.')
            ? candidate.replace(/\./g, '').replace(/,/g, '.')
            : candidate.replace(/,/g, '')
    } else if (hasComma) {
        candidate = candidate.replace(/,/g, '.')
    }

    const normalized = Number(candidate)
    return Number.isFinite(normalized) ? normalized : null
}

/**
 * Fetch only the records synced from the mobile app.
 * Shared source priority:
 * 1. `observations` rows with a populated `client_uuid`
 * 2. Legacy mobile tables
 */
export async function fetchMobileObservationRecords(): Promise<MobileObservationRecord[]> {
    let lastUnexpectedError: unknown = null
    let primaryRecords: MobileObservationRecord[] = []

    try {
        const { data, error } = await supabase
            .from('observations')
            .select(`
                id,
                client_uuid,
                collector_id,
                section_name,
                block_id,
                field_name,
                latitude,
                longitude,
                gps_accuracy,
                date_recorded,
                created_at,
                crop_information(crop_type, variety, crop_stage),
                crop_monitoring(canopy_cover, stress)
            `)
            .not('client_uuid', 'is', null)
            .neq('client_uuid', '')
            .order('date_recorded', { ascending: false })

        if (error) {
            if (!isMissingRelationError(error)) {
                lastUnexpectedError = error
            }
        } else if (data && data.length > 0) {
            primaryRecords = data.map((row) => mapPrimaryMobileObservation(row as ObservationSelectRow))
        }
    } catch (error) {
        if (!isMissingRelationError(error)) {
            lastUnexpectedError = error
        }
    }

    if (primaryRecords.length > 0) {
        return attachFieldRegistry(primaryRecords)
    }

    const fallbackTables = ['observations_raw', 'field_observations', 'observation', 'observations_raw_v1']

    for (const table of fallbackTables) {
        try {
            const { data, error } = await supabase
                .from(table)
                .select('*')
                .order('created_at', { ascending: false })
                .limit(1000)

            if (error) {
                if (!isMissingRelationError(error)) {
                    lastUnexpectedError = error
                }
                continue
            }

            if (data && data.length > 0) {
                return attachFieldRegistry(data.map((row) => mapLegacyMobileRow(row as Record<string, unknown>, table)))
            }
        } catch (error) {
            if (!isMissingRelationError(error)) {
                lastUnexpectedError = error
            }
        }
    }

    if (lastUnexpectedError) {
        console.error('Error fetching mobile observation records:', lastUnexpectedError)
        throw lastUnexpectedError
    }

    return []
}

/**
 * Fetch all observations with related data
 */
export async function fetchObservations(filters?: ObservationFilters): Promise<FullObservation[]> {
    // Shared preferred table
    console.log('🔍 fetchObservations called with filters:', filters)
    let lastUnexpectedError: unknown = null
    let primaryObservations: FullObservation[] = []

    try {
        let query = supabase
            .from('observations')
            .select(`
      *,
      crop_information(*),
      crop_monitoring(*),
      soil_characteristics(*),
      irrigation_management(*),
      nutrient_management(*),
      crop_protection(*),
      control_methods(*),
      harvest(*),
      residual_management(*),
      images(*)
    `)
            .order('date_recorded', { ascending: false })

        // Apply filters (only for primary schema that has nested selects)
        if (hasActiveFilterValue(filters?.cropType)) {
            query = query.eq('crop_information.crop_type', filters.cropType)
        }
        if (hasActiveFilterValue(filters?.variety)) {
            query = query.eq('crop_information.variety', filters.variety)
        }
        if (hasActiveFilterValue(filters?.fieldName)) {
            query = query.eq('field_name', filters.fieldName)
        }
        if (hasActiveFilterValue(filters?.section)) {
            query = query.eq('section_name', filters.section)
        }
        if (hasActiveFilterValue(filters?.block)) {
            query = query.eq('block_id', filters.block)
        }
        if (filters?.startDate) {
            query = query.gte('date_recorded', filters.startDate)
        }
        if (filters?.endDate) {
            query = query.lte('date_recorded', filters.endDate)
        }
        if (hasActiveFilterValue(filters?.stressLevel)) {
            query = query.eq('crop_monitoring.stress', filters.stressLevel)
        }

        const { data, error } = await query
        console.log('📊 Primary query result - Data length:', data?.length || 0, 'Error:', error)

        if (error) {
            // If the primary table doesn't exist, fall through to fallback logic
            if (/relation|does not exist|undefined table/i.test(String(error.message || error))) {
                console.warn('⚠️ Primary observations table not available, attempting fallbacks')
            } else {
                console.error('--- fetchObservations Failed ---')
                console.error('Error Details:', error)
                lastUnexpectedError = error
            }
        } else if (data && (data as any).length > 0) {
            console.log('✅ Successfully fetched', data.length, 'observations from primary table')
            // Transform the data to match FullObservation interface
            // Supabase returns arrays for related tables, but we want single objects
            primaryObservations = (data as any[]).map((obs: any) => {
                return {
                    ...obs,
                    crop_information: getSingleRelation(obs.crop_information),
                    crop_monitoring: getSingleRelation(obs.crop_monitoring),
                    soil_characteristics: getSingleRelation(obs.soil_characteristics),
                    irrigation_management: getSingleRelation(obs.irrigation_management),
                    nutrient_management: getSingleRelation(obs.nutrient_management),
                    crop_protection: getSingleRelation(obs.crop_protection),
                    control_methods: getSingleRelation(obs.control_methods),
                    harvest: getSingleRelation(obs.harvest),
                    residual_management: getSingleRelation(obs.residual_management),
                    // images is already an array, so keep it as is
                }
            })
        }
    } catch (err: any) {
        if (!isMissingRelationError(err)) {
            lastUnexpectedError = err
        }
        console.warn('Error querying primary observations table, will try fallbacks.', err?.message || err)
    }

    let entryFormRecords: MobileObservationRecord[] = []

    const combinedObservations = primaryObservations

    if (combinedObservations.length > 0) {
        return filterObservations(combinedObservations, filters)
    }

    try {
        const sugarcaneMonitoringRecords = await fetchSugarcaneMonitoringObservations(filters)

        if (sugarcaneMonitoringRecords.length > 0) {
            console.log(`✅ Using sugarcane_monitoring fallback with ${sugarcaneMonitoringRecords.length} records.`)
            return filterObservations(sugarcaneMonitoringRecords, filters)
        }
    } catch (error) {
        if (!isMissingRelationError(error)) {
            lastUnexpectedError = error
        }
    }

    // Fallback: try a set of alternative table names that mobile app might have written to
    const fallbackTables = ['observations_raw', 'field_observations', 'observation', 'observation_images', 'observations_raw_v1']
    console.log('🔄 Trying fallback tables...')

    for (const table of fallbackTables) {
        try {
            console.log(`  ↳ Attempting fallback table: "${table}"`)
            const { data, error } = await supabase.from(table).select('*').order('created_at', { ascending: false }).limit(1000)
            
            if (error) {
                // table may not exist, continue
                console.log(`    ✗ Table "${table}" failed:`, error.message)
                continue
            }

            if (!data || (data as any[]).length === 0) {
                console.log(`    ⊘ Table "${table}" returned empty`)
                continue
            }

            console.log(`    ✓ Found ${data.length} records in "${table}"`)

            // Map rows to FullObservation where possible using common field names
            const mapped: FullObservation[] = (data as any[]).map((row: any) => {
                const mappedRow: any = {
                    id: row.id || row._id || row.uuid || (row.client_uuid ? String(row.client_uuid) : undefined),
                    client_uuid: row.client_uuid || row.clientId || null,
                    collector_id: row.collector_id || row.user_id || row.created_by || null,
                    section_name: row.section_name || row.section || row.zone || null,
                    block_id: row.block_id || row.block || row.block_number || null,
                    field_name: row.field_name || row.field || row.fieldId || null,
                    latitude: Number(row.latitude || row.lat || row.coords?.lat || row.location?.lat) || 0,
                    longitude: Number(row.longitude || row.lon || row.lng || row.coords?.lng || row.location?.lng) || 0,
                    gps_accuracy: row.gps_accuracy || row.accuracy || null,
                    date_recorded: row.date_recorded || row.recorded_at || row.created_at || row.timestamp || new Date().toISOString(),
                    created_at: row.created_at || row.timestamp || new Date().toISOString(),
                    // leave related nested objects undefined; UI handles missing subfields gracefully
                }

                return mappedRow as FullObservation
            })

            const filteredMapped = filterObservations(mapped, filters)
            console.log(`✅ Using fallback table '${table}' and mapped ${filteredMapped.length} rows to FullObservation shape.`)
            return filteredMapped
        } catch (err) {
            // continue to next fallback
            console.log(`    ✗ Exception in fallback table "${table}":`, err)
            continue
        }
    }

    // Nothing found
    if (lastUnexpectedError) {
        console.error('❌ Failed to fetch observation data from all supported sources:', lastUnexpectedError)
        throw lastUnexpectedError
    }

    console.warn('❌ No observation data found in primary or fallback tables')
    return []
}

/**
 * Fetch a single observation by ID with all related data
 */
export async function fetchObservationById(id: string): Promise<FullObservation | null> {
    const { data, error } = await supabase
        .from('observations')
        .select(`
      *,
      crop_information(*),
      crop_monitoring(*),
      soil_characteristics(*),
      irrigation_management(*),
      nutrient_management(*),
      crop_protection(*),
      control_methods(*),
      harvest(*),
      residual_management(*),
      images(*)
    `)
        .eq('id', id)
        .single()

    if (error) {
        console.error('Error fetching observation:', error)
        throw error
    }

    // Transform the data to match FullObservation interface
    const transformedData = data ? {
        ...data,
        crop_information: getSingleRelation((data as any).crop_information),
        crop_monitoring: getSingleRelation((data as any).crop_monitoring),
        soil_characteristics: getSingleRelation((data as any).soil_characteristics),
        irrigation_management: getSingleRelation((data as any).irrigation_management),
        nutrient_management: getSingleRelation((data as any).nutrient_management),
        crop_protection: getSingleRelation((data as any).crop_protection),
        control_methods: getSingleRelation((data as any).control_methods),
        harvest: getSingleRelation((data as any).harvest),
        residual_management: getSingleRelation((data as any).residual_management),
        // images is already an array
    } : null

    return transformedData as FullObservation
}

/**
 * Delete an observation (admin/supervisor)
 * Cascades to related tables via database constraints
 */
export async function deleteObservation(id: string): Promise<void> {
    // Explicitly delete related records first to handle cases where ON DELETE CASCADE might be missing
    const tables = [
        'crop_information',
        'crop_monitoring',
        'soil_characteristics',
        'irrigation_management',
        'nutrient_management',
        'crop_protection',
        'control_methods',
        'harvest',
        'residual_management',
        'images' // Assuming images metadata table is linked
    ]

    // We use Promise.all to delete parallel, but we need to handle them carefully.
    // Actually, simple sequential or parallel delete is fine.
    const deletePromises = tables.map(table =>
        supabase.from(table).delete().eq('observation_id', id)
    )

    await Promise.all(deletePromises)

    // Now delete the parent observation
    const { error, count } = await supabase
        .from('observations')
        .delete({ count: 'exact' })
        .eq('id', id)

    console.log('Delete operation result:', { id, error, count })

    if (error) {
        console.error('Error deleting observation:', error)
        throw error
    }
}

export async function deleteMobileObservationRecord(record: FullObservation | MobileObservationRecord): Promise<void> {
    // observation_entry_form table has been disconnected from the web app
    // All mobile observations are now stored in the observations table
    
    if (!isMobileObservationRecord(record) || record.source_table === 'observations') {
        await deleteObservation(record.id)
        return
    }

    // observation_entry_form and other legacy mobile tables are no longer supported
    throw new Error(`observation_entry_form table has been disconnected. All records must be stored in the observations table.`)
}

/**
 * Delete ALL recorded field observations from the database
 * WARNING: This is irreversible - removes all field recordings
 */
export async function deleteAllObservations(): Promise<{ deletedCount: number }> {
    try {
        // Delete all related records first
        const tables = [
            'crop_information',
            'crop_monitoring',
            'soil_characteristics',
            'irrigation_management',
            'nutrient_management',
            'crop_protection',
            'control_methods',
            'harvest',
            'residual_management',
            'images'
        ]

        // Delete all records from related tables
        const deleteRelatedPromises = tables.map(table =>
            supabase.from(table).delete().neq('id', '')  // Delete all rows
        )

        await Promise.all(deleteRelatedPromises)
        console.log('✓ Deleted all related observation records')

        // Delete all observations
        const { error, count } = await supabase
            .from('observations')
            .delete({ count: 'exact' })
            .neq('id', '')  // Delete all rows

        if (error) {
            console.error('Error deleting all observations:', error)
            throw error
        }

        console.log(`✓ Deleted ${count} observations from database`)
        return { deletedCount: count || 0 }
    } catch (error) {
        console.error('Error in deleteAllObservations:', error)
        throw error
    }
}

/**
 * Create a new observation with all related data
 */
export async function createObservation(observation: FullObservation): Promise<FullObservation> {
    console.log('✨ Creating new observation:', observation)
    
    // Generate new ID if not provided
    const id = observation.id || crypto.randomUUID()
    const createdAt = new Date().toISOString()
    const clientUuid = observation.client_uuid?.trim() || `web-${id}`
    const dateRecorded = observation.date_recorded || createdAt
    
    const { error: obsError, data: createdObs } = await supabase
        .from('observations')
        .insert({
            id,
            client_uuid: clientUuid,
            collector_id: observation.collector_id,
            section_name: observation.section_name,
            block_id: observation.block_id,
            field_name: observation.field_name,
            latitude: observation.latitude,
            longitude: observation.longitude,
            gps_accuracy: observation.gps_accuracy || 0,
            date_recorded: dateRecorded,
            created_at: createdAt,
        })
        .select()
        .single()

    if (obsError) {
        console.error('❌ Error creating observation:', obsError)
        throw obsError
    }

    console.log('✓ Created observation:', createdObs)

    // Create related records in parallel
    const promises = []

    if (observation.crop_information) {
        promises.push(
            supabase
                .from('crop_information')
                .insert({ ...observation.crop_information, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.crop_monitoring) {
        promises.push(
            supabase
                .from('crop_monitoring')
                .insert({ ...observation.crop_monitoring, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.soil_characteristics) {
        promises.push(
            supabase
                .from('soil_characteristics')
                .insert({ ...observation.soil_characteristics, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.irrigation_management) {
        promises.push(
            supabase
                .from('irrigation_management')
                .insert({ ...observation.irrigation_management, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.nutrient_management) {
        promises.push(
            supabase
                .from('nutrient_management')
                .insert({ ...observation.nutrient_management, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.crop_protection) {
        promises.push(
            supabase
                .from('crop_protection')
                .insert({ ...observation.crop_protection, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.control_methods) {
        promises.push(
            supabase
                .from('control_methods')
                .insert({ ...observation.control_methods, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.harvest) {
        promises.push(
            supabase
                .from('harvest')
                .insert({ ...observation.harvest, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    if (observation.residual_management) {
        promises.push(
            supabase
                .from('residual_management')
                .insert({ ...observation.residual_management, observation_id: id, id: crypto.randomUUID() })
                .select()
        )
    }

    const results = await Promise.all(promises)
    const errors = results.filter(r => r.error).map(r => r.error)

    if (errors.length > 0) {
        console.error('⚠️ Errors creating related records:', errors)
        throw new Error('Failed to create some related data')
    }

    console.log('✓ Created all related observation data')

    // Return the created observation with related data
    return {
        ...observation,
        id,
        client_uuid: clientUuid,
        date_recorded: dateRecorded,
        created_at: createdObs?.created_at || new Date().toISOString(),
    }
}

/**
 * Fetch unique fields with GPS coordinates and latest data
 */
export async function fetchFields(): Promise<Field[]> {
    try {
        const { data, error } = await supabase
            .from('observations')
            .select(`
          field_name,
          section_name,
          block_id,
          latitude,
          longitude,
          date_recorded,
          crop_information(crop_type, variety, crop_stage),
          crop_monitoring(stress, crop_vigor, canopy_cover, remarks),
          irrigation_management(soil_moisture_percentage, irrigation_type),
          control_methods(weed_control, pest_control, disease_control),
          images(image_url)
        `)
            .order('date_recorded', { ascending: false })

        if (error) {
            if (!isMissingRelationError(error)) {
                console.error('Error fetching fields:', error)
                throw error
            }
        } else {
            const fieldsMap = new Map<string, Field>()

            data?.forEach((obs: any) => {
                const key = `${obs.section_name}-${obs.block_id}-${obs.field_name}`
                const hasPestControl = obs.control_methods?.pest_control && obs.control_methods.pest_control !== 'None'
                const hasDiseaseControl = obs.control_methods?.disease_control && obs.control_methods.disease_control !== 'None'
                const isSprayed = hasPestControl || hasDiseaseControl

                if (!fieldsMap.has(key)) {
                    fieldsMap.set(key, {
                        field_name: obs.field_name,
                        section_name: obs.section_name,
                        block_id: obs.block_id,
                        latitude: obs.latitude,
                        longitude: obs.longitude,
                        crop_type: obs.crop_information?.crop_type,
                        latest_variety: obs.crop_information?.variety,
                        latest_stage: obs.crop_information?.crop_stage,
                        latest_vigor: obs.crop_monitoring?.crop_vigor,
                        latest_canopy_cover: obs.crop_monitoring?.canopy_cover,
                        latest_stress: obs.crop_monitoring?.stress,
                        latest_moisture: obs.irrigation_management?.soil_moisture_percentage,
                        latest_irrigation_type: obs.irrigation_management?.irrigation_type,
                        latest_pest_control: obs.control_methods?.pest_control,
                        latest_disease_control: obs.control_methods?.disease_control,
                        latest_weed_control: obs.control_methods?.weed_control,
                        latest_remarks: obs.crop_monitoring?.remarks,
                        latest_image: obs.images?.[0]?.image_url,
                        observation_count: 1,
                        is_sprayed: isSprayed,
                        last_spray_date: isSprayed ? obs.date_recorded : undefined,
                        latest_observation_date: obs.date_recorded,
                        updated_at: obs.date_recorded,
                    })
                } else {
                    const existing = fieldsMap.get(key)!
                    existing.observation_count++
                }
            })

            if (fieldsMap.size > 0) {
                return Array.from(fieldsMap.values())
            }
        }
    } catch (error) {
        if (!isMissingRelationError(error)) {
            console.warn('Falling back to field registry + mobile entry-form records for field aggregation.', error)
        }
    }

    const [registryFields, mobileRecords] = await Promise.all([
        fetchPredefinedFields().catch(() => [] as PredefinedField[]),
        fetchMobileObservationRecords().catch(() => [] as MobileObservationRecord[]),
    ])

    const fieldsMap = new Map<string, Field>()

    registryFields.forEach((field) => {
        const key = buildFieldLookupKey(field.field_name, field.section_name, field.block_id)
        fieldsMap.set(key, {
            ...field,
            observation_count: 0,
            latest_observation_date: field.date_recorded || field.updated_at || field.local_updated_at || field.created_at,
        })
    })

    mobileRecords.forEach((record) => {
        const linkedField = record.field_registry || null
        const fieldName = linkedField?.field_name || record.field_name || record.entry_form?.selected_field || 'Unknown field'
        const sectionName = linkedField?.section_name || record.section_name || ''
        const blockId = linkedField?.block_id || record.block_id || ''
        const key = buildFieldLookupKey(fieldName, sectionName, blockId) || `${record.source_table}-${record.source_row_id || record.id}`
        const recordDate = record.date_recorded || record.entry_form?.date_recorded || record.created_at
        const current = fieldsMap.get(key)

        if (!current) {
            fieldsMap.set(key, {
                id: linkedField?.id,
                field_name: fieldName,
                section_name: sectionName,
                block_id: blockId,
                latitude: linkedField?.latitude ?? record.latitude ?? 0,
                longitude: linkedField?.longitude ?? record.longitude ?? 0,
                geom: linkedField?.geom,
                created_at: linkedField?.created_at,
                created_by: linkedField?.created_by,
                date_recorded: linkedField?.date_recorded,
                is_synced: linkedField?.is_synced,
                local_updated_at: linkedField?.local_updated_at,
                updated_at: linkedField?.updated_at || recordDate,
                crop_type: record.crop_information?.crop_type || record.entry_form?.crop_class,
                latest_variety: record.crop_information?.variety || record.entry_form?.variety,
                latest_stage: record.crop_information?.crop_stage,
                latest_vigor: record.crop_monitoring?.crop_vigor,
                latest_canopy_cover: record.crop_monitoring?.canopy_cover,
                latest_stress: record.crop_monitoring?.stress,
                latest_moisture: record.irrigation_management?.soil_moisture_percentage,
                latest_irrigation_type: record.entry_form?.irrigation_type || record.irrigation_management?.irrigation_type,
                latest_remarks: record.entry_form?.remarks || record.crop_monitoring?.remarks,
                latest_image: record.images?.[0]?.image_url,
                observation_count: 1,
                latest_observation_date: recordDate,
            })
            return
        }

        current.observation_count += 1

        const currentTimestamp = new Date(current.latest_observation_date || 0).getTime()
        const incomingTimestamp = new Date(recordDate || 0).getTime()

        if (!Number.isFinite(incomingTimestamp) || incomingTimestamp < currentTimestamp) {
            return
        }

        current.latitude = linkedField?.latitude ?? record.latitude ?? current.latitude
        current.longitude = linkedField?.longitude ?? record.longitude ?? current.longitude
        current.crop_type = record.crop_information?.crop_type || record.entry_form?.crop_class || current.crop_type
        current.latest_variety = record.crop_information?.variety || record.entry_form?.variety || current.latest_variety
        current.latest_stage = record.crop_information?.crop_stage || current.latest_stage
        current.latest_vigor = record.crop_monitoring?.crop_vigor || current.latest_vigor
        current.latest_canopy_cover = record.crop_monitoring?.canopy_cover ?? current.latest_canopy_cover
        current.latest_stress = record.crop_monitoring?.stress || current.latest_stress
        current.latest_moisture = record.irrigation_management?.soil_moisture_percentage ?? current.latest_moisture
        current.latest_irrigation_type = record.entry_form?.irrigation_type || record.irrigation_management?.irrigation_type || current.latest_irrigation_type
        current.latest_remarks = record.entry_form?.remarks || record.crop_monitoring?.remarks || current.latest_remarks
        current.latest_image = record.images?.[0]?.image_url || current.latest_image
        current.latest_observation_date = recordDate || current.latest_observation_date
        current.updated_at = linkedField?.updated_at || current.updated_at || recordDate || current.updated_at
    })

    return Array.from(fieldsMap.values()).sort((left, right) => {
        const sectionCompare = (left.section_name || '').localeCompare(right.section_name || '')
        if (sectionCompare !== 0) return sectionCompare

        const blockCompare = (left.block_id || '').localeCompare(right.block_id || '')
        if (blockCompare !== 0) return blockCompare

        return (left.field_name || '').localeCompare(right.field_name || '')
    })
}

/**
 * Fetch distinct crop types for filters
 */
export async function fetchCropTypes(): Promise<string[]> {
    const mobileRecords = await fetchMobileObservationRecords().catch(() => [] as MobileObservationRecord[])
    const sharedCropTypes = [...new Set(
        mobileRecords
            .map((record) => record.crop_information?.crop_type || record.entry_form?.crop_class || '')
            .filter(Boolean)
    )].sort((left, right) => left.localeCompare(right))

    if (sharedCropTypes.length > 0) {
        return sharedCropTypes
    }

    try {
        const { data, error } = await supabase
            .from('crop_information')
            .select('crop_type')

        if (error) {
            if (!isMissingRelationError(error)) {
                console.error('Error fetching crop types:', error)
                throw error
            }
        } else {
            const uniqueTypes = [...new Set(data?.map(item => item.crop_type) || [])]
            if (uniqueTypes.length > 0) {
                return uniqueTypes.filter(Boolean) as string[]
            }
        }
    } catch (error) {
        if (!isMissingRelationError(error)) {
            console.warn('Falling back to shared observation crop types.', error)
        }
    }

    return []
}

/**
 * Fetch distinct field names for filters
 */
export async function fetchFieldNames(): Promise<string[]> {
    const predefined = await fetchPredefinedFields().catch(() => [] as PredefinedField[])
    const mobileRecords = await fetchMobileObservationRecords().catch(() => [] as MobileObservationRecord[])
    const sharedFieldNames = [...new Set([
        ...predefined.map((field) => field.field_name).filter(Boolean),
        ...mobileRecords.map((record) => record.field_name || record.entry_form?.selected_field || '').filter(Boolean),
    ])].sort((left, right) => left.localeCompare(right))

    if (sharedFieldNames.length > 0) {
        return sharedFieldNames
    }

    try {
        const { data, error } = await supabase
            .from('observations')
            .select('field_name')

        if (error) {
            if (/relation|does not exist|undefined table/i.test(String(error.message || error))) {
                return []
            }
            throw error
        }

        const uniqueFields = [...new Set(data?.map(item => item.field_name) || [])].filter(Boolean) as string[]
        if (uniqueFields.length > 0) return uniqueFields
        return []
    } catch (error) {
        console.warn('Falling back to shared observation field names.', error)
        return []
    }
}

/**
 * Update a mobile observation record based on its backing source table
 */
export async function updateMobileObservationRecord(record: FullObservation | MobileObservationRecord): Promise<void> {
    // observation_entry_form table has been disconnected from the web app
    // All observations must be stored in the observations table
    
    if (!isMobileObservationRecord(record) || record.source_table === 'observations') {
        await updateObservation(record)
        return
    }

    throw new Error(`observation_entry_form table has been disconnected. All records must be stored in the observations table. Edit operations are no longer supported for legacy source tables.`)
}

/**
 * Update an observation and its related tables
 */
export async function updateObservation(observation: FullObservation): Promise<void> {
    const { id, ...updates } = observation

    // Update main observation details
    const { error: obsError } = await supabase
        .from('observations')
        .update({
            collector_id: updates.collector_id,
            client_uuid: updates.client_uuid || null,
            field_name: updates.field_name,
            section_name: updates.section_name,
            block_id: updates.block_id,
            latitude: updates.latitude,
            longitude: updates.longitude,
            gps_accuracy: updates.gps_accuracy,
            date_recorded: updates.date_recorded,
        })
        .eq('id', id)

    if (obsError) throw obsError

    // Use Promise.all for parallel updates of related tables
    const promises = []

    if (updates.crop_information) {
        promises.push(
            supabase
                .from('crop_information')
                .upsert({ ...updates.crop_information, observation_id: id })
        )
    }

    if (updates.crop_monitoring) {
        promises.push(
            supabase
                .from('crop_monitoring')
                .upsert({ ...updates.crop_monitoring, observation_id: id })
        )
    }

    if (updates.irrigation_management) {
        promises.push(
            supabase
                .from('irrigation_management')
                .upsert({ ...updates.irrigation_management, observation_id: id })
        )
    }

    if (updates.nutrient_management) {
        promises.push(
            supabase
                .from('nutrient_management')
                .upsert({ ...updates.nutrient_management, observation_id: id })
        )
    }

    if (updates.soil_characteristics) {
        promises.push(
            supabase
                .from('soil_characteristics')
                .upsert({ ...updates.soil_characteristics, observation_id: id })
        )
    }

    if (updates.crop_protection) {
        promises.push(
            supabase
                .from('crop_protection')
                .upsert({ ...updates.crop_protection, observation_id: id })
        )
    }

    if (updates.control_methods) {
        promises.push(
            supabase
                .from('control_methods')
                .upsert({ ...updates.control_methods, observation_id: id })
        )
    }

    if (updates.harvest) {
        promises.push(
            supabase
                .from('harvest')
                .upsert({ ...updates.harvest, observation_id: id })
        )
    }

    if (updates.residual_management) {
        promises.push(
            supabase
                .from('residual_management')
                .upsert({ ...updates.residual_management, observation_id: id })
        )
    }

    const results = await Promise.all(promises)
    const errors = results.filter(r => r.error).map(r => r.error)

    if (errors.length > 0) {
        console.error('Errors updating related tables:', errors)
        throw new Error('Failed to update some related data')
    }
}


