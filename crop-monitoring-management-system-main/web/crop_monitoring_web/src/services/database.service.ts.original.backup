/**
 * Fetch all data from all tables in Supabase
 */
export async function fetchAllData() {
    try {
        const [
            observations,
            blocks,
            cropInformation,
            cropMonitoring,
            soilCharacteristics,
            irrigationManagement,
            nutrientManagement,
            cropProtection,
            controlMethods,
            harvestInformation,
            residualManagement,
            observationImages,
            profiles
        ] = await Promise.all([
            fetchObservations(),
            fetchBlocks(),
            fetchAllCropInformation(),
            fetchAllCropMonitoring(),
            fetchAllSoilCharacteristics(),
            fetchAllIrrigationManagement(),
            fetchAllNutrientManagement(),
            fetchAllCropProtection(),
            fetchAllControlMethods(),
            fetchAllHarvestInformation(),
            fetchAllResidualManagement(),
            fetchAllObservationImages(),
            // Import and call fetchStaff from staff.service
            (await import('@/services/staff.service')).fetchStaff()
        ])

        return {
            observations,
            blocks,
            cropInformation,
            cropMonitoring,
            soilCharacteristics,
            irrigationManagement,
            nutrientManagement,
            cropProtection,
            controlMethods,
            harvestInformation,
            residualManagement,
            observationImages,
            profiles
        }
    } catch (error) {
        console.error('Error fetching all data:', error)
        throw error
    }
}

function mapSugarcaneMonitoringRowToEntryForm(
    row: SugarcaneMonitoringRecord,
    linkedField?: PredefinedField | null
): ObservationEntryForm {
    return {
        id: row.id,
        client_uuid: row.id,
        collector_id: row.collector_id,
        selected_field: linkedField?.field_name || row.field_name,
        section_name: row.section_name || linkedField?.section_name || '',
        field_name: row.field_name || linkedField?.field_name || '',
        block_id: row.block_id || linkedField?.block_id || '',
        block_size: undefined,
        spatial_data: linkedField?.geom ?? null,
        latitude: preferRegistryCoordinate(row.latitude, linkedField?.latitude) ?? row.latitude,
        longitude: preferRegistryCoordinate(row.longitude, linkedField?.longitude) ?? row.longitude,
        gps_accuracy: undefined,
        date_recorded: row.date_recorded,
        trial_number: undefined,
        trial_name: '',
        contact_person: '',
        phone_country_code: '',
        phone_number: '',
        crop_class: row.crop_type || linkedField?.crop_type || '',
        variety: row.variety || '',
        planting_date: row.planting_date || '',
        cutting_date: '',
        expected_harvest_date: row.expected_harvest_date || '',
        irrigation_type: row.irrigation_type || '',
        water_source: row.water_source || '',
        tamm_area: undefined,
        soil_type: row.soil_type || '',
        soil_ph: row.soil_ph ?? undefined,
        crop_vigor: row.crop_vigor || '',
        canopy_cover: row.canopy_cover ?? undefined,
        stress: row.stress || '',
        yield: row.yield ?? undefined,
        harvest_method: row.harvest_method || '',
        remarks: row.remarks || '',
        source_table: 'sugarcane_monitoring',
        created_at: row.created_at,
        updated_at: row.updated_at,
    }
}

function buildSugarcaneMonitoringPayload(submission: ObservationEntryFormSubmissionInput) {
    return {
        collector_id: toNullableString(submission.collector_id),
        field_name: toNullableString(submission.field_name),
        section_name: toNullableString(submission.section_name),
        block_id: toNullableString(submission.block_id),
        latitude: toNullableNumber(submission.latitude),
        longitude: toNullableNumber(submission.longitude),
        date_recorded: toNullableString(submission.date_recorded),
        crop_type: toNullableString(submission.crop_class) || 'Sugarcane',
        variety: toNullableString(submission.variety),
        planting_date: toNullableString(submission.planting_date),
        expected_harvest_date: toNullableString(submission.expected_harvest_date),
        irrigation_type: toNullableString(submission.irrigation_type),
        water_source: toNullableString(submission.water_source),
        soil_type: toNullableString(submission.soil_type),
        soil_ph: toNullableNumber(submission.soil_ph),
        remarks: toNullableString(submission.remarks),
    }
}

/**
 * Fetch observation entry forms with sugarcane_monitoring as the preferred source.
 */
export async function fetchObservationEntryForms(): Promise<ObservationEntryForm[]> {
    console.log('🔍 fetchObservationEntryForms called')

    const registryFields = await fetchPredefinedFields().catch(() => [] as PredefinedField[])
    const lookups = registryFields.length > 0 ? buildFieldLookupMaps(registryFields) : null

    try {
        const monitoringRows = await fetchSugarcaneMonitoringRows()

        if (monitoringRows.length > 0) {
            console.log(`✅ Successfully fetched ${monitoringRows.length} monitoring-backed entry rows`)

            return monitoringRows.map((row) => {
                const linkedField = lookups
                    ? resolveLinkedFieldRegistry(
                        {
                            field_name: row.field_name,
                            selected_field: row.field_name,
                            section_name: row.section_name,
                            block_id: row.block_id,
                        },
                        lookups
                    )
                    : null

                return mapSugarcaneMonitoringRowToEntryForm(row, linkedField)
            })
        }
    } catch (error) {
        if (!isMissingRelationError(error)) {
            console.warn('Falling back to observation_entry_form after monitoring fetch failed.', error)
        }
    }

    try {
        const { data, error } = await supabase
            .from('observation_entry_form')
            .select('*')
            .order('date_recorded', { ascending: false })

        if (error) {
            console.error('❌ Error fetching observation entry forms:', error)
            throw error
        }

        console.log(`✅ Successfully fetched ${data?.length || 0} observation entry forms`)
        if (!lookups) {
            return (data || []) as ObservationEntryForm[]
        }

        return (data || []).map((row: any) => {
            const linkedField = resolveLinkedFieldRegistry(
                {
                    field_name: row.field_name,
                    selected_field: row.selected_field,
                    section_name: row.section_name,
                    block_id: row.block_id,
                },
                lookups
            )

            return {
                ...row,
                selected_field: row.selected_field || linkedField?.field_name || row.field_name,
                field_name: row.field_name || linkedField?.field_name || row.selected_field,
                section_name: row.section_name || linkedField?.section_name || '',
                block_id: row.block_id || linkedField?.block_id || '',
                latitude: preferRegistryCoordinate(Number(row.latitude), linkedField?.latitude) ?? row.latitude,
                longitude: preferRegistryCoordinate(Number(row.longitude), linkedField?.longitude) ?? row.longitude,
                spatial_data: row.spatial_data ?? null,
                source_table: 'observation_entry_form',
            } satisfies ObservationEntryForm
        })
    } catch (error) {
        console.error('Error in fetchObservationEntryForms:', error)
        throw error
    }
}

async function syncMirroredObservationForEntryForm(
    clientUuid: string,
    resolvedSubmission: ObservationEntryFormSubmissionInput
): Promise<void> {
    try {
        const collectorId = resolvedSubmission.collector_id || ''
        const baseSeed = {
            client_uuid: clientUuid,
            collector_id: collectorId,
            field_name: resolvedSubmission.field_name,
            section_name: resolvedSubmission.section_name,
            block_id: resolvedSubmission.block_id || '',
            latitude: resolvedSubmission.latitude || 0,
            longitude: resolvedSubmission.longitude || 0,
            gps_accuracy: resolvedSubmission.gps_accuracy || 0,
            date_recorded: resolvedSubmission.date_recorded,
            crop_information: {
                crop_type: resolvedSubmission.crop_class || '',
                variety: resolvedSubmission.variety || '',
                planting_date: resolvedSubmission.planting_date || '',
                expected_harvest_date: resolvedSubmission.expected_harvest_date || '',
            },
            crop_monitoring: {
                remarks: resolvedSubmission.remarks || '',
            },
            soil_characteristics: {
                soil_type: resolvedSubmission.soil_type || '',
                soil_ph: resolvedSubmission.soil_ph || 0,
            },
            irrigation_management: {
                irrigation_type: resolvedSubmission.irrigation_type || '',
                water_source: resolvedSubmission.water_source || '',
            },
        } satisfies Parameters<typeof buildObservationDraft>[1]

        const { data, error } = await supabase
            .from('observations')
            .select('id')
            .eq('client_uuid', clientUuid)

        if (error) {
            if (isMissingRelationError(error)) {
                console.warn('Skipping mirrored observation sync because the observations table is not available.', error)
                return
            }

            throw error
        }

        const observationIds = (data || [])
            .map((row) => String(row.id || '').trim())
            .filter(Boolean)

        if (observationIds.length === 0) {
            await createObservation(buildObservationDraft(collectorId, baseSeed))
            return
        }

        for (const observationId of observationIds) {
            const existingObservation = await fetchObservationById(observationId)

            if (!existingObservation) {
                continue
            }

            await updateObservation(buildObservationDraft(collectorId, {
                ...existingObservation,
                ...baseSeed,
                id: existingObservation.id,
                crop_information: {
                    ...existingObservation.crop_information,
                    ...baseSeed.crop_information,
                },
                crop_monitoring: {
                    ...existingObservation.crop_monitoring,
                    ...baseSeed.crop_monitoring,
                },
                soil_characteristics: {
                    ...existingObservation.soil_characteristics,
                    ...baseSeed.soil_characteristics,
                },
                irrigation_management: {
                    ...existingObservation.irrigation_management,
                    ...baseSeed.irrigation_management,
                },
            }))
        }
    } catch (error) {
        if (isMissingRelationError(error)) {
            console.warn('Skipping mirrored observation sync because a related observation table is unavailable.', error)
            return
        }

        throw error
    }
}

async function syncMirroredObservationForEntryFormBestEffort(
    clientUuid: string,
    resolvedSubmission: ObservationEntryFormSubmissionInput
): Promise<void> {
    try {
        await syncMirroredObservationForEntryForm(clientUuid, resolvedSubmission)
    } catch (error) {
        console.warn(
            'Continuing with observation_entry_form as the shared source of truth because the legacy observations mirror could not be updated.',
            error
        )
    }
}

export async function updateObservationEntryFormSubmission(
    entryFormId: number | string,
    submission: ObservationEntryFormSubmissionInput,
    predefinedFields?: PredefinedField[]
): Promise<void> {
    const isMonitoringEntry = typeof entryFormId === 'string'

    if (isMonitoringEntry) {
        const { submission: resolvedSubmission } = await resolveObservationEntrySubmission(submission, predefinedFields)
        const payload = buildSugarcaneMonitoringPayload(resolvedSubmission)
        const { error } = await supabase
            .from('sugarcane_monitoring')
            .update(payload)
            .eq('id', entryFormId)

        if (error) {
            throw error
        }

        return
    }

    const { data: existingEntryForm, error: fetchError } = await supabase
        .from('observation_entry_form')
        .select('id, client_uuid')
        .eq('id', entryFormId)
        .single()

    if (fetchError) {
        throw fetchError
    }

    const clientUuid = submission.client_uuid?.trim()
        || String(existingEntryForm?.client_uuid || '').trim()
        || `entry-${entryFormId}`

    const { submission: resolvedSubmission } = await resolveObservationEntrySubmission(
        {
            ...submission,
            client_uuid: clientUuid,
        },
        predefinedFields
    )

    const payload = {
        client_uuid: clientUuid,
        collector_id: toNullableString(resolvedSubmission.collector_id),
        selected_field: toNullableString(resolvedSubmission.selected_field || resolvedSubmission.field_name),
        field_name: toNullableString(resolvedSubmission.field_name),
        section_name: toNullableString(resolvedSubmission.section_name),
        block_id: toNullableString(resolvedSubmission.block_id),
        block_size: toNullableNumber(resolvedSubmission.block_size),
        spatial_data: resolvedSubmission.spatial_data ?? null,
        latitude: toNullableNumber(resolvedSubmission.latitude),
        longitude: toNullableNumber(resolvedSubmission.longitude),
        gps_accuracy: toNullableNumber(resolvedSubmission.gps_accuracy),
        date_recorded: toNullableString(resolvedSubmission.date_recorded),
        trial_number: toNullableNumber(resolvedSubmission.trial_number),
        trial_name: toNullableString(resolvedSubmission.trial_name),
        contact_person: toNullableString(resolvedSubmission.contact_person),
        phone_country_code: toNullableString(resolvedSubmission.phone_country_code),
        phone_number: toNullableString(resolvedSubmission.phone_number),
        crop_class: toNullableString(resolvedSubmission.crop_class),
        variety: toNullableString(resolvedSubmission.variety),
        planting_date: toNullableString(resolvedSubmission.planting_date),
        cutting_date: toNullableString(resolvedSubmission.cutting_date),
        expected_harvest_date: toNullableString(resolvedSubmission.expected_harvest_date),
        irrigation_type: toNullableString(resolvedSubmission.irrigation_type),
        water_source: toNullableString(resolvedSubmission.water_source),
        tamm_area: toNullableNumber(resolvedSubmission.tamm_area),
        soil_type: toNullableString(resolvedSubmission.soil_type),
        soil_ph: toNullableNumber(resolvedSubmission.soil_ph),
        remarks: toNullableString(resolvedSubmission.remarks),
    }

    const { error: updateError } = await supabase
        .from('observation_entry_form')
        .update(payload)
        .eq('id', entryFormId)

    if (updateError) {
        throw updateError
    }

    await syncMirroredObservationForEntryFormBestEffort(clientUuid, resolvedSubmission)
}

export async function createObservationEntryFormSubmission(
    submission: ObservationEntryFormSubmissionInput,
    predefinedFields?: PredefinedField[]
): Promise<void> {
    const { submission: resolvedSubmission } = await resolveObservationEntrySubmission(submission, predefinedFields)
    const payload = buildSugarcaneMonitoringPayload(resolvedSubmission)

    const { error } = await supabase
        .from('sugarcane_monitoring')
        .insert(payload)

    if (error) {
        throw error
    }
}

export async function bulkCreateObservationEntryFormSubmissions(
    rows: ObservationEntryImportRow[]
): Promise<ObservationEntryBulkImportResult> {
    const failures: string[] = []
    let insertedCount = 0
    const predefinedFields = await fetchPredefinedFields().catch(() => [] as PredefinedField[])

    for (const row of rows) {
        try {
            await createObservationEntryFormSubmission(row.submission, predefinedFields)
            insertedCount += 1
        } catch (error: any) {
            failures.push(`Row ${row.rowNumber}: ${error.message || 'Failed to import row.'}`)
        }
    }

    return {
        insertedCount,
        failureCount: failures.length,
        failures,
    }
}
